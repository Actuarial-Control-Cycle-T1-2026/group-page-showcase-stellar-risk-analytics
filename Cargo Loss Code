### Scenario/Stress Tests
run_stress <- function(freq_mult = 1, sev_mult = 1, n_sims = 100000) {
  stressed_losses <- numeric(n_sims)
  
  for (i in 1:n_sims) {
    N <- rpois(1, lambda = lambda_total * freq_mult)
    stressed_losses[i] <- sum(r_severity(N, mu, sigma) * sev_mult)
  }
  
  c(
    Mean = mean(stressed_losses),
    SD = sd(stressed_losses),
    VaR99 = unname(quantile(stressed_losses, 0.99)),
    TVaR99 = mean(stressed_losses[stressed_losses >= quantile(stressed_losses, 0.99)])
  )
}

baseline <- run_stress(1.0, 1.0)
freq_50  <- run_stress(1.5, 1.0)
sev_50   <- run_stress(1.0, 1.5)
both_50  <- run_stress(1.5, 1.5)
