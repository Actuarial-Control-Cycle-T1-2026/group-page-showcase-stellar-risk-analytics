### Compute Tail Metrics 

r_sev <- function(n, mu, sigma) {
  if (n <= 0) return(numeric(0))
  rlnorm(n, meanlog = mu, sdlog = sigma)
}

tail_metrics <- function(x) {
  VaR_95  <- unname(quantile(x, 0.95))
  TVaR_95 <- mean(x[x >= VaR_95])
  VaR_99  <- unname(quantile(x, 0.99))
  TVaR_99 <- mean(x[x >= VaR_99])
  
  data.frame(
    Mean = mean(x),
    Standard_Deviation = sd(x),
    P95 = VaR_95,
    P99 = VaR_99,
    VaR_95 = VaR_95,
    TVaR_95 = TVaR_95,
    VaR_99 = VaR_99,
    TVaR_99 = TVaR_99
  )
}

